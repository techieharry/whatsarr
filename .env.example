# whatsarr config — copy to `.env` and fill in your values.
# Do not commit `.env`; it's in .gitignore.

# ---- Seerr (or Overseerr / Jellyseerr) ----
# The base URL of your Seerr instance. If you bind to a private network
# interface (Tailscale / Wireguard), use that address here.
SEERR_URL=http://your-seerr-host:5055
# API key from Seerr → Settings → General.
SEERR_API_KEY=
# Seerr user id that owns bot-created requests (Settings → Users → Edit → URL).
SEERR_DEFAULT_USER_ID=1
# Optional: shared secret on the webhook. If set, Seerr must send the same
# value in `X-Webhook-Secret` for the bot to accept the callback.
SEERR_WEBHOOK_SECRET=

# ---- WhatsApp ----
# Bot's WhatsApp account (used for documentation only; the live identity is
# stored in the auth dir after the QR pair).
BOT_WHATSAPP_NUMBER=+15555550100
# Comma-separated group JIDs the bot will respond in (e.g.
# `120363xxxxxxxxx@g.us`). Run `npm run discover` after pairing to dump the
# JIDs of every group the bot is a member of.
ALLOWED_GROUPS=
# Comma-separated bare numbers for admin-class actions (also receive
# `!feedback` / `!issue` DM reports). E.g. ADMIN_NUMBERS=+15555550100
ADMIN_NUMBERS=

# ---- Behavior ----
COMMAND_PREFIX=!
REQUESTS_PER_DAY=5
DEDUP_WINDOW_HOURS=1
CONFIRM_TTL_MINUTES=10

# ---- Webhook (Seerr → whatsarr "ready" callback) ----
WEBHOOK_ENABLED=true
WEBHOOK_PORT=5056
# 127.0.0.1 = localhost only. 0.0.0.0 = all interfaces (set this if Seerr runs
# in Docker and reaches the bot via host.docker.internal).
WEBHOOK_BIND=127.0.0.1

# ---- Storage ----
DB_PATH=data/whatsarr.sqlite
AUTH_DIR=auth_info_baileys

# ---- Logging ----
LOG_LEVEL=info

# ---- Optional: Syncthing (powers the !sync command) ----
# Leave SYNCTHING_URL / SYNCTHING_API_KEY blank to disable.
SYNCTHING_URL=
SYNCTHING_API_KEY=
SYNCTHING_FOLDER_ID=
SYNCTHING_REMOTE_DEVICE_ID=
SYNCTHING_REMOTE_LABEL=remote
